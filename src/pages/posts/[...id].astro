---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import PostShare from '../../components/PostShare.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Disqus from '../../components/Disqus.astro';
import { settings } from '../../data/settings';

function getVideoEmbedUrl(url: string): string {
  // If already player.bilibili.com, return as-is
  if (url.includes('player.bilibili.com')) {
    return url;
  }

  // Extract BV ID from bilibili.com/video/BVxxxxx
  const bvMatch = url.match(/bilibili\.com\/video\/(BV\w+)/);
  if (bvMatch) {
    return `https://player.bilibili.com/player.html?bvid=${bvMatch[1]}`;
  }

  // Extract AV ID from bilibili.com/video/avXXXXX
  const avMatch = url.match(/bilibili\.com\/video\/av(\d+)/);
  if (avMatch) {
    return `https://player.bilibili.com/player.html?aid=${avMatch[1]}`;
  }

  // Return original URL for other video sources (YouTube, Vimeo, etc.)
  return url;
}

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { data } = post;
const { Content } = await render(post);
const postUrl = new URL(Astro.url.pathname, settings.site.url).toString();
const shareImage = data.image
  ? typeof data.image === 'string'
    ? data.image
    : new URL(data.image.src, settings.site.url).toString()
  : undefined;
---

<BaseLayout
  title={data.title}
  description={data.description}
  image={typeof data.image === 'string' ? data.image : data.image?.src}
>
  <div class='post-head'>
    <div class='container'>
      <div class='row'>
        {
          data.videoEmbed ? (
            <div class='col col-12'>
              <div class='post-video'>
                <div class='post-video__wrap'>
                  <iframe
                    src={getVideoEmbedUrl(data.videoEmbed)}
                    loading='lazy'
                    width='640'
                    height='360'
                    frameborder='0'
                    allowfullscreen
                  />
                </div>
              </div>
            </div>
          ) : (
            data.image && (
              <div class='col col-6 col-d-12'>
                <div class='post-image'>
                  {typeof data.image === 'string' ? (
                    <img src={data.image} alt={data.title} loading='eager' />
                  ) : (
                    <Image src={data.image} alt={data.title} loading='eager' />
                  )}
                </div>
              </div>
            )
          )
        }

        <div class={data.videoEmbed ? 'col col-12' : 'col col-6 col-d-12'}>
          <div
            class={`post__info ${data.videoEmbed ? 'post__info-video' : ''}`}
          >
            {
              data.tags && data.tags.length >= 1 && (
                <div class='post__tags'>
                  {data.tags.map((tag: string) => (
                    <a href={`/tags#${tag}`} class='post__tag'>
                      {tag}
                    </a>
                  ))}
                </div>
              )
            }

            <h1 class='post__title'>{data.title}</h1>

            <div class='post__meta'>
              <a href='/about/' class='post__author-image'>
                <Image
                  src={settings.author.src}
                  alt={settings.author.name}
                  loading='eager'
                />
              </a>

              <div class='post__meta-bottom'>
                <a class='post__author' href='/about/'>{settings.author.name}</a
                >
                <time class='post__date' datetime={data.pubDate.toISOString()}>
                  <FormattedDate date={data.pubDate} />
                </time>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class='container animate'>
    <article class='post'>
      <div class='post__content'>
        <Content />
      </div>

      <PostShare
        title={data.title}
        url={postUrl}
        image={shareImage}
        description={data.description}
      />
    </article>
  </div>

  <RelatedPosts currentTags={data.tags} currentId={post.id} />

  {settings.comments.enabled && <Disqus identifier={post.id} url={postUrl} />}
</BaseLayout>
