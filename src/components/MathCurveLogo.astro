---
interface Props {
  size?: number;
}

const { size = 34 } = Astro.props;
---

<span class='math-curve-logo' style={`--logo-size: ${size}px;`} aria-hidden='true'>
  <svg viewBox='0 0 100 100' role='img' focusable='false'>
    <title>Math curve animated logo</title>
    <g class='math-curve-logo__group'>
      <path
        class='math-curve-logo__trail'
        d='M50 10 C74 10 90 26 90 50 C90 74 74 90 50 90 C26 90 10 74 10 50 C10 26 26 10 50 10 Z'
      />
      <path
        class='math-curve-logo__curve'
        d='M50 12 C67 12 83 24 83 38 C83 53 67 62 50 62 C33 62 17 72 17 88 M50 12 C33 12 17 24 17 38 C17 53 33 62 50 62 C67 62 83 72 83 88'
      />
      <circle class='math-curve-logo__dot' cx='50' cy='12' r='4' />
    </g>
  </svg>
</span>

<style>
  .math-curve-logo {
    width: var(--logo-size);
    height: var(--logo-size);
    display: inline-flex;
    color: currentColor;
  }

  .math-curve-logo svg {
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .math-curve-logo__group {
    transform-origin: 50px 50px;
    animation: math-curve-spin 5.2s linear infinite;
  }

  .math-curve-logo__trail,
  .math-curve-logo__curve {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .math-curve-logo__trail {
    stroke: currentColor;
    stroke-width: 5;
    opacity: 0.16;
  }

  .math-curve-logo__curve {
    stroke: currentColor;
    stroke-width: 5;
    stroke-dasharray: 34 260;
    stroke-dashoffset: 0;
    animation: math-curve-dash 2.1s ease-in-out infinite;
  }

  .math-curve-logo__dot {
    fill: currentColor;
    animation: math-curve-pulse 1.2s ease-in-out infinite;
    transform-origin: 50px 50px;
  }

  @keyframes math-curve-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes math-curve-dash {
    0% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -294;
    }
  }

  @keyframes math-curve-pulse {
    0%,
    100% {
      transform: scale(0.8);
      opacity: 0.7;
    }
    50% {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>
